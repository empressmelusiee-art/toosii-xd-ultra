# ── TOOSII-XD Bot Configuration ──────────────────────────────────────────

  # Session ID from toosii-xd pairing (required)
  SESSION_ID=

  # Your WhatsApp number with country code, no + or spaces (required)
  OWNER_NUMBER=254700000000

  # Bot command prefix (default: .)
  PREFIX=.

  # Bot name shown in messages
  BOT_NAME=TOOSII-XD

  # public = anyone can use | private = owner/sudo only
  MODE=public

  # Your name shown in menu/footer
  OWNER_NAME=TOOSII

  # Timezone for time-based responses
  TIME_ZONE=Africa/Nairobi

  # Port for health check web server (auto-set on most platforms)
  PORT=3000

  # ── API Keys (set via .setapi command or here) ─────────────────────────────
  OPENAI_API_KEY=
  GEMINI_API_KEY=
  WEATHER_API_KEY=
  NEWSAPI_API_KEY=
  RAPIDAPI_API_KEY=
  